# BuilderOS environment template — copy to .env and fill in.
# Generate secrets with: gh2 secrets .env DATABASE_URL API_SECRET_KEY

# GitHub auto-sync (used by scripts/sync-github.ps1)
GITHUB_USERNAME=
GITHUB_REPO=builder-os

# Deployment
VERCEL_TOKEN=

# Database (for scaffolded projects)
DATABASE_URL=
REDIS_URL=

# Secrets — replace with generated values, never commit real ones
API_SECRET_KEY=
