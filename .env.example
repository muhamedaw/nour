# Copy this file to .env and fill in your values
# Never commit .env to git

# App
APP_NAME=nour
APP_ENV=development
APP_PORT=3000

# Shared staff login (one password for all staff, no per-role accounts — v1)
STAFF_PASSWORD=change-me

# --- OTA update publishing (scripts/build-apk.ps1 only, dev machine only) --
# Copy these into .env.local (gitignored, never .env) to enable the
# optional OTA-publish step in scripts/build-apk.ps1. This service_role key
# is a build-time-only secret — it must NEVER end up in the APK bundle.
# The app itself only ever uses the low-privilege anon/publishable key
# hardcoded in lib/cloud/defaults.ts, which only needs write access to
# backups/ — see components/settings/CloudBackupStatus.tsx.
#
# SUPABASE_OTA_BUCKET must be a SEPARATE, genuinely public bucket from
# SUPABASE_BUCKET — Supabase's unauthenticated public-read path is gated by
# the bucket's own public flag, not per-path policies, so the private
# backups bucket can never serve the app-updates manifest/zip. See the
# SUPABASE_OTA_BUCKET doc comment in lib/cloud/defaults.ts.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_BUCKET=nour-backups
SUPABASE_OTA_BUCKET=nour-app-updates
SUPABASE_SERVICE_ROLE_KEY=change-me
