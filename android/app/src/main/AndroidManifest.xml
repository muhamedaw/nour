<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

        <!--
            "sensor" (not "landscape") so the app follows the device
            rotation. The configChanges list above already includes
            "orientation" + "screenSize", so the activity is NOT
            recreated on rotation — the WebView just receives a
            window resize event and the existing Tailwind responsive
            classes (md:*, lg:*) re-flow the layout. Both portrait
            and landscape work; reverse-portrait + reverse-landscape
            too. Locking to landscape was wrong for a staff-facing POS
            that often needs to be held one-handed in portrait to scan
            a product, then set down in landscape for the floor grid.

            XML-comment placement: this comment is intentionally a
            sibling of <activity>, NOT between its attributes. XML
            doesn't allow comments between attributes of a single
            element — the parser fails with "Element type 'activity'
            must be followed by either attribute specifications, '>'
            or '/>'." (lesson learned the hard way when this blocked
            the first 3 CI builds).
        -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:screenOrientation="sensor">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep-link reset: a QR code, NFC tag, or `adb shell am start`
                 that fires `nour-floor://settings` brings staff straight
                 back to the launcher so they can reconfigure the LAN
                 address without uninstalling. The launcher's JS listens
                 for `appUrlOpen` events (see capacitor-launcher/launcher.js)
                 and clears the saved URL on this scheme. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="nour-floor" android:host="settings" />
                <data android:scheme="nour-floor" android:host="reset" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <!-- Required for the WebView to fetch from / navigate to the LAN
         Next.js server. The Power Wall feature flag is not used. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Reserved for future "are we on WiFi vs offline" UI badges. The
         launcher itself doesn't currently inspect NetworkInfo, but the
         permission is harmless to declare and unblocks future work
         (e.g. @capacitor/network plugin) without a manifest bump. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
</manifest>
