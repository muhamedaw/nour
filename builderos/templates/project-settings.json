{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python builderos/scripts/hook.py session"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python builderos/scripts/hook.py prompt"
          }
        ]
      }
    ]
  }
}
