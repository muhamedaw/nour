{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Claude Code (plan mode)",
      "type": "shell",
      "command": "claude --permission-mode plan",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "Plan Chat (Qwen 14B, Arabic, free)",
      "type": "shell",
      "command": "python builderos/scripts/plan_chat.py qwen2.5:14b",
      "options": {
        "env": {
          "PYTHONUTF8": "1",
          "PYTHONIOENCODING": "utf-8"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
